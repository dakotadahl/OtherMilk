---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Base title="Page Not Found — Other Milk">
  <Nav />
  <main id="main" class="not-found">
    <h1 class="not-found__title">404</h1>
    <p class="not-found__subtitle">Outta milk.</p>
    <p class="not-found__text">
      The page you&rsquo;re looking for has been moved, removed,
      or never existed in the first place.
    </p>
    <a href="/" class="not-found__btn">Back to the good stuff</a>
  </main>
  <Footer />
</Base>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 60vh;
    padding: clamp(60px, 10vw, 120px) 20px;
  }

  .not-found__title {
    font-family: var(--font-display);
    font-size: clamp(80px, 15vw, 200px);
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-pop);
  }

  .not-found__subtitle {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 36px);
    text-transform: uppercase;
    color: var(--color-dark);
    margin-top: 8px;
  }

  .not-found__text {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 380px;
    margin-top: 16px;
    text-wrap: pretty;
  }

  .not-found__btn {
    display: inline-block;
    margin-top: 32px;
    padding: 14px 32px;
    background: var(--color-pop);
    color: var(--color-white);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    border-radius: var(--radius-card);
    transition: box-shadow 0.2s ease;
  }

  .not-found__btn:hover {
    box-shadow: var(--shadow-postcard);
  }

  .not-found__btn:focus-visible {
    outline: 2px solid var(--color-dark);
    outline-offset: 2px;
  }
</style>
