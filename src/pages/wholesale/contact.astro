---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
---

<Base
  title="Wholesale Inquiry — Other Milk"
  description="Get in touch about wholesale pricing, minimums, and delivery for Other Milk pecan milk."
>
  <Nav />
  <main id="main">
    <section class="contact">
      <div class="contact__header">
        <a href="/wholesale" class="contact__back" aria-label="Back to wholesale">&larr; Wholesale</a>
        <h1 class="contact__title">Get in Touch</h1>
        <p class="contact__subtitle">
          Please share your information and we&rsquo;ll get back to you as soon as possible. Thanks for your interest in wholesaling Other Milk!
        </p>
      </div>

      <div class="contact__form-wrap">
        <iframe
          data-tally-src="https://tally.so/embed/68v1Xk?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="1"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Wholesale inquiry form"
          class="contact__form"
        ></iframe>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<script is:inline>
  // Tally embed loader
  var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach(function(e){e.src=e.dataset.tallySrc})};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w;s.onload=v;s.onerror=v;d.body.appendChild(s)}else v();
</script>

<style>
  .contact {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: 0 20px clamp(60px, 8.33vw, 120px);
  }

  .contact__header {
    max-width: 640px;
    margin: clamp(40px, 5.56vw, 80px) auto 0;
    text-align: center;
  }

  .contact__back {
    display: inline-block;
    margin-bottom: clamp(16px, 1.67vw, 24px);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 4.2px;
    text-transform: uppercase;
    color: var(--color-pop-accessible);
    font-feature-settings: 'dlig';
    transition: opacity 0.2s;
  }

  .contact__back:hover {
    opacity: 0.7;
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.86vw, 70px);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--color-pop);
  }

  .contact__subtitle {
    margin-top: clamp(12px, 1.25vw, 18px);
    font-size: clamp(15px, 1.11vw, 16px);
    line-height: 1.5;
    color: var(--color-muted);
  }

  .contact__form-wrap {
    max-width: 640px;
    margin: clamp(24px, 2.78vw, 40px) auto 0;
  }

  .contact__form {
    border: none;
  }
</style>
