---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Headline from '../components/Headline.astro';
import ProductSection from '../components/ProductSection.astro';
import LifestyleBanner from '../components/LifestyleBanner.astro';
import PressSection from '../components/PressSection.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Base>
  <Nav />
  <main id="main">
    <Hero />
    <Headline />
    <ProductSection />
    <LifestyleBanner />
    <PressSection />
  </main>
  <Footer />
</Base>

<script>
  const targets = document.querySelectorAll('.products, .banner, .footer__wordmark');
  targets.forEach((el) => el.classList.add('scroll-reveal'));

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  targets.forEach((el) => observer.observe(el));

  // Parallax for hero and banner images
  const parallaxTargets = document.querySelectorAll<HTMLImageElement>(
    '.hero__image-wrap img, .banner__image-wrap img'
  );

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    function updateParallax() {
      for (const img of parallaxTargets) {
        const wrap = img.closest('.hero__image-wrap, .banner__image-wrap') as HTMLElement;
        if (!wrap) continue;
        const rect = wrap.getBoundingClientRect();
        const viewH = window.innerHeight;
        // 0 when top enters viewport, 1 when bottom leaves
        const progress = (viewH - rect.top) / (viewH + rect.height);
        // Shift image from 0% to -20% of its extra height
        const offset = Math.max(0, Math.min(1, progress)) * -20;
        img.style.transform = `translateY(${offset}%)`;
      }
      requestAnimationFrame(updateParallax);
    }
    requestAnimationFrame(updateParallax);
  }
</script>
