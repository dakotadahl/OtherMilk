---
import type { Review } from '../data/reviews';

interface Props {
  reviews: Review[];
}

const { reviews } = Astro.props;
---

<section class="proof" aria-label="Customer reviews">
  <div class="proof__inner">
    <div class="proof__header">
      <svg class="proof__star-icon" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M13.85 2.68L9.6 6.92L13.85 11.17L11.17 13.85L6.92 9.6L2.68 13.85L0 11.17L4.24 6.92L0 2.68L2.68 0L6.92 4.24L11.17 0L13.85 2.68Z" fill="var(--color-pop)"/>
      </svg>
      <h2 class="proof__title">Don&rsquo;t take our<br />word for it.</h2>
      <svg class="proof__star-icon" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M13.85 2.68L9.6 6.92L13.85 11.17L11.17 13.85L6.92 9.6L2.68 13.85L0 11.17L4.24 6.92L0 2.68L2.68 0L6.92 4.24L11.17 0L13.85 2.68Z" fill="var(--color-pop)"/>
      </svg>
    </div>

    <div class="proof__carousel" aria-roledescription="carousel" aria-label="Customer reviews carousel" tabindex="0">
      <div class="proof__track" aria-live="off">
        {reviews.map((review, i) => (
          <blockquote
            class="review"
            style={`--review-rot: ${(i % 2 === 0 ? 1 : -1) * (0.4 + i * 0.25)}deg`}
          >
            <div class="review__stars" role="img" aria-label={`${review.stars} out of 5 stars`}>
              {Array.from({ length: review.stars }).map(() => (
                <svg class="review__star" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="var(--color-pop)"/>
                </svg>
              ))}
            </div>
            <p class="review__text">&ldquo;{review.text}&rdquo;</p>
            <footer class="review__author">
              <cite class="review__name">{review.name}</cite>
            </footer>
          </blockquote>
        ))}
      </div>

      <div class="proof__dots" aria-label="Review navigation">
        {reviews.map((_, i) => (
          <button
            class:list={['proof__dot', { 'proof__dot--active': i === 0 }]}
            aria-label={`Go to review ${i + 1}`}
            data-index={i}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .proof {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: clamp(40px, 5.56vw, 80px) 20px;
  }

  .proof__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .proof__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: clamp(40px, 4.17vw, 60px);
  }

  .proof__star-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .proof__title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.17vw, 60px);
    text-transform: uppercase;
    color: var(--color-pop-accessible);
    line-height: 0.95;
    text-align: center;
  }

  .proof__carousel {
    overflow: hidden;
    position: relative;
    cursor: grab;
    padding: 12px 0;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    padding-left: max(20px, calc((100vw - 1100px) / 2));
    padding-right: max(20px, calc((100vw - 1100px) / 2));
    mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent);
  }

  .proof__carousel:active {
    cursor: grabbing;
  }

  .proof__track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    gap: clamp(20px, 2.08vw, 30px);
  }

  .proof__track.is-dragging {
    transition: none;
  }

  .review {
    background: var(--color-white);
    border: 1px solid var(--color-pop);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-postcard);
    padding: clamp(24px, 2.22vw, 32px);
    rotate: var(--review-rot);
    display: flex;
    flex-direction: column;
    flex: 0 0 var(--card-width);
    aspect-ratio: 1 / 1;
    min-width: 0;
    overflow-y: auto;
    user-select: none;
    -webkit-user-select: none;
  }

  .review__stars {
    display: flex;
    gap: 4px;
    margin-bottom: clamp(12px, 1.11vw, 16px);
  }

  .review__star {
    width: 12px;
    height: 12px;
  }

  .review__text {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.11vw, 16px);
    line-height: 1.55;
    color: var(--color-dark);
    flex: 1;
    text-wrap: pretty;
  }

  .review__author {
    margin-top: clamp(16px, 1.39vw, 20px);
    padding-top: clamp(12px, 1.04vw, 16px);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .review__name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    font-style: normal;
    color: var(--color-dark);
  }

  .proof__dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: clamp(24px, 2.08vw, 32px);
  }

  .proof__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--color-pop);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .proof__dot--active {
    background: var(--color-pop);
    transform: scale(1.2);
  }

  .proof__dot:hover:not(.proof__dot--active) {
    background: rgba(254, 35, 87, 0.3);
  }

  @media (max-width: 768px) {
    .review {
      rotate: 0deg;
    }
  }
</style>

<script>
  function initReviewCarousels() {
    document.querySelectorAll<HTMLElement>('.proof__carousel').forEach((carousel) => {
      const track = carousel.querySelector<HTMLElement>('.proof__track');
      const dots = carousel.querySelectorAll<HTMLButtonElement>('.proof__dot');
      const originalCards = Array.from(carousel.querySelectorAll<HTMLElement>('.review'));
      if (!track || originalCards.length === 0) return;

      const totalOriginal = originalCards.length;
      let autoTimer: ReturnType<typeof setInterval> | null = null;

      function getPerPage(): number {
        if (window.innerWidth <= 480) return 1;
        if (window.innerWidth <= 768) return 2;
        return 3;
      }

      function getGap(): number {
        return parseFloat(getComputedStyle(track!).columnGap) || 24;
      }

      function updateCardWidths() {
        const style = getComputedStyle(carousel);
        const visibleWidth = carousel.clientWidth - parseFloat(style.paddingLeft) - parseFloat(style.paddingRight);
        const perPage = getPerPage();
        const gap = getGap();
        const cardWidth = (visibleWidth - (perPage - 1) * gap) / perPage;
        carousel.style.setProperty('--card-width', `${cardWidth}px`);
      }

      // Clone enough cards to fill a full page past the end for seamless looping
      function setupClones() {
        track!.querySelectorAll('.review--clone').forEach((c) => c.remove());
        const perPage = getPerPage();
        for (let i = 0; i < perPage; i++) {
          const clone = originalCards[i % totalOriginal].cloneNode(true) as HTMLElement;
          clone.classList.add('review--clone');
          clone.setAttribute('aria-hidden', 'true');
          track!.appendChild(clone);
        }
      }

      function getAllCards(): HTMLElement[] {
        return Array.from(track!.querySelectorAll<HTMLElement>('.review'));
      }

      let currentIndex = 0;

      function getSlideOffset(index: number): number {
        const allCards = getAllCards();
        if (index >= allCards.length) return 0;
        return allCards[index].offsetLeft - allCards[0].offsetLeft;
      }

      function updateDots() {
        const wrappedIndex = currentIndex % totalOriginal;
        dots.forEach((dot, i) => {
          const active = i === wrappedIndex;
          dot.classList.toggle('proof__dot--active', active);
          dot.setAttribute('aria-selected', String(active));
        });
      }

      function goTo(index: number, animate = true) {
        currentIndex = index;
        if (!animate) {
          track!.style.transition = 'none';
        }
        track!.style.transform = `translateX(-${getSlideOffset(currentIndex)}px)`;
        if (!animate) {
          // Force reflow then restore transition
          track!.offsetHeight;
          track!.style.transition = '';
        }
        updateDots();
      }

      // After transition ends on a clone, snap back to the real card
      track.addEventListener('transitionend', () => {
        if (currentIndex >= totalOriginal) {
          goTo(currentIndex % totalOriginal, false);
        }
      });

      function next() {
        goTo(currentIndex + 1);
      }

      function prev() {
        if (currentIndex > 0) {
          goTo(currentIndex - 1);
        } else {
          // Jump to the last real card without animation, then stay
          goTo(totalOriginal - 1, false);
        }
      }

      // Dot click
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          stopAuto();
          goTo(Number(dot.dataset.index));
          startAuto();
        });
      });

      // Drag / swipe
      let dragStartX = 0;
      let dragOffset = 0;
      let isDragging = false;

      function onPointerDown(e: PointerEvent) {
        isDragging = true;
        dragStartX = e.clientX;
        dragOffset = getSlideOffset(currentIndex);
        track!.classList.add('is-dragging');
        carousel.setPointerCapture(e.pointerId);
        stopAuto();
      }

      function onPointerMove(e: PointerEvent) {
        if (!isDragging) return;
        const dx = e.clientX - dragStartX;
        track!.style.transform = `translateX(${-dragOffset + dx}px)`;
      }

      function onPointerUp(e: PointerEvent) {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        const dx = e.clientX - dragStartX;
        const threshold = carousel.offsetWidth * 0.15;
        if (dx < -threshold) {
          next();
        } else if (dx > threshold) {
          prev();
        } else {
          goTo(currentIndex);
        }
        startAuto();
      }

      carousel.addEventListener('pointerdown', onPointerDown);
      carousel.addEventListener('pointermove', onPointerMove);
      carousel.addEventListener('pointerup', onPointerUp);
      carousel.addEventListener('pointercancel', onPointerUp);
      carousel.addEventListener('dragstart', (e) => e.preventDefault());

      // Keyboard navigation
      carousel.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          stopAuto();
          next();
          startAuto();
        } else if (e.key === 'ArrowLeft') {
          e.preventDefault();
          stopAuto();
          prev();
          startAuto();
        }
      });

      // Auto-advance
      function startAuto() {
        if (autoTimer) return;
        autoTimer = setInterval(next, 5000);
      }
      function stopAuto() {
        if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
      }

      // Recalc on resize
      window.addEventListener('resize', () => {
        updateCardWidths();
        setupClones();
        if (currentIndex >= totalOriginal) currentIndex = currentIndex % totalOriginal;
        goTo(currentIndex, false);
      });

      updateCardWidths();
      setupClones();
      startAuto();
      carousel.addEventListener('mouseenter', stopAuto);
      carousel.addEventListener('mouseleave', startAuto);
      carousel.addEventListener('focusin', stopAuto);
      carousel.addEventListener('focusout', startAuto);
    });
  }

  initReviewCarousels();
</script>
