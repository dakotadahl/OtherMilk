---
import SubscribeBtn from './SubscribeBtn.astro';
---

<section class="sub-promo" aria-label="Subscribe and save">
  <h2 class="sub-promo__title">Never Run&nbsp;Out.</h2>
  <p class="sub-promo__script">make other milk a staple</p>

  <div class="sub-promo__cards">
    <div class="sub-promo__card sub-promo__card--save">
      <span class="sub-promo__card-icon" aria-hidden="true">$</span>
      <div class="sub-promo__card-text">
        <h3 class="sub-promo__card-title">Save every&nbsp;week</h3>
        <p class="sub-promo__card-desc">
          Subscribers save at least <strong>10%</strong> on every bottle. That's more
          milk money for&hellip;more milk!
        </p>
      </div>
    </div>

    <div class="sub-promo__card sub-promo__card--staple">
      <span class="sub-promo__card-icon" aria-hidden="true">&infin;</span>
      <div class="sub-promo__card-text">
        <h3 class="sub-promo__card-title">Always stocked</h3>
        <p class="sub-promo__card-desc">
          Fresh milk weekly, no waste&mdash;and your fridge never goes without!
        </p>
      </div>
    </div>

    <div class="sub-promo__card sub-promo__card--flex">
      <span class="sub-promo__card-icon" aria-hidden="true">&olarr;</span>
      <div class="sub-promo__card-text">
        <h3 class="sub-promo__card-title">Totally flexible</h3>
        <p class="sub-promo__card-desc">
          Skip a week, pause for vacation, or cancel for good&mdash;no fees,
          no guilt, no fine print.
        </p>
      </div>
    </div>
  </div>

  <div class="sub-promo__actions">
    <SubscribeBtn productId={418874} label="Start your subscription" directCheckout />
    <span class="sub-promo__aside">Cancel or pause anytime.</span>
  </div>
</section>

<style>
  .sub-promo {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: clamp(40px, 5.56vw, 80px) clamp(20px, 4.24vw, 61px);
    text-align: center;
  }

  .sub-promo__title {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.47vw, 50px);
    line-height: 1.05;
    text-transform: uppercase;
    color: var(--color-pop-accessible);
  }

  .sub-promo__script {
    margin-top: clamp(8px, 0.83vw, 12px);
    font-family: 'Melany Lane', cursive;
    font-size: clamp(22px, 2.08vw, 30px);
    color: var(--color-pop-accessible);
    line-height: 1.4;
  }

  .sub-promo__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 1.39vw, 20px);
    max-width: 1100px;
    margin: clamp(32px, 3.47vw, 50px) auto 0;
  }

  .sub-promo__card {
    display: flex;
    align-items: flex-start;
    gap: clamp(12px, 1.11vw, 16px);
    background: var(--color-white);
    border: 1px solid var(--color-pop);
    border-radius: var(--radius-card);
    padding: clamp(20px, 1.67vw, 24px);
    box-shadow: var(--shadow-postcard);
    text-align: left;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .sub-promo__card:hover {
    box-shadow:
      -2px 4px 6px rgba(0, 0, 0, 0.06),
      0 4px 24px rgba(0, 0, 0, 0.14),
      -1px 2px 3px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .sub-promo__card--save { rotate: -0.8deg; }
  .sub-promo__card--staple { rotate: 0.5deg; }
  .sub-promo__card--flex { rotate: -0.3deg; }

  .sub-promo__card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--color-pop-accessible);
    border: 2px solid var(--color-pop-accessible);
    border-radius: 100px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 18px;
    transition: background 0.25s, color 0.25s;
  }

  .sub-promo__card:hover .sub-promo__card-icon {
    background: var(--color-pop-accessible);
    color: var(--color-white);
  }

  .sub-promo__card-title {
    font-family: var(--font-display);
    font-size: clamp(14px, 1.11vw, 16px);
    text-transform: uppercase;
    color: var(--color-pop-accessible);
    letter-spacing: 0.5px;
    line-height: 1.2;
  }

  .sub-promo__card-desc {
    margin-top: 4px;
    font-family: var(--font-body);
    font-size: clamp(13px, 0.97vw, 14px);
    line-height: 1.55;
    color: var(--color-dark);
  }

  .sub-promo__card-desc strong {
    color: var(--color-pop-accessible);
    font-weight: 700;
  }

  .sub-promo__actions {
    margin-top: clamp(32px, 2.78vw, 40px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .sub-promo__aside {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .sub-promo__cards {
      grid-template-columns: 1fr;
      max-width: 480px;
    }

    .sub-promo__card {
      rotate: 0deg;
    }

    .sub-promo__actions {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
