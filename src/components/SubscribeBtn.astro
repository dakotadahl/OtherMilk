---
interface Props {
  class?: string;
  productId?: number;
  label?: string;
}

const { class: className, productId, label = 'Subscribe' } = Astro.props;
const href = productId
  ? `https://www.subbly.co/checkout/buy/${productId}`
  : '#cart';
const cartToggle = !productId;
---

<a
  href={href}
  class:list={['btn', className, { 'subbly-cart': cartToggle }]}
>{label}</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 18px 8px;
    background-color: var(--color-pop-accessible);
    color: var(--color-white);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 4.2px;
    text-transform: uppercase;
    border-radius: 2px;
    font-feature-settings: 'dlig';
    transition: opacity 0.2s, transform 0.15s ease;
    white-space: nowrap;
  }

  .btn:hover {
    opacity: 0.85;
  }

  .btn:active {
    transform: scale(0.96);
  }
</style>
