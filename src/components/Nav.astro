---
import SubscribeBtn from './SubscribeBtn.astro';
---

<header class="nav">
  <nav class="nav__left" aria-label="Site navigation">
    <a href="/about" class="nav__link">About</a>
    <a href="/find-us" class="nav__link">Find Us</a>
    <a href="/products" class="nav__link">Products</a>
  </nav>

  <a href="/" class="nav__logo" aria-label="Other Milk home">
    <img class="nav__logo-full" src="/images/logomark.svg" alt="Other Milk" width="164" height="78" decoding="async" />
    <img class="nav__logo-sm" src="/images/Logomark_sm.svg" alt="Other Milk" width="165" height="44" decoding="async" />
  </a>

  <nav class="nav__links" aria-label="Account and cart">
    <a href="#cart" class="nav__cart subbly-cart" aria-label="Cart"><span class="nav__cart-label" aria-hidden="true">Cart</span><span class="nav__cart-count subbly-cart-product-count" role="status" aria-live="polite"></span></a>
    <SubscribeBtn productId={418874} />
    <a href="https://www.subbly.co/account/auth/login?store=drinkother" class="nav__login" target="_blank" rel="noopener noreferrer">Log in</a>
  </nav>
</header>

<style>
  .nav {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: var(--page-max);
    margin: 0 auto;
    padding: clamp(24px, 3.47vw, 50px) clamp(20px, 4.24vw, 61px) clamp(16px, 2.78vw, 40px);
  }

  .nav__logo {
    display: block;
  }

  .nav__logo-full {
    width: clamp(100px, 11.39vw, 164px);
    height: auto;
    aspect-ratio: 164 / 78;
    object-fit: contain;
  }

  .nav__logo-sm {
    display: none;
    width: 80px;
    height: auto;
  }

  .nav__left {
    position: absolute;
    left: clamp(20px, 4.24vw, 61px);
    display: flex;
    align-items: center;
    gap: clamp(12px, 2.78vw, 40px);
  }

  .nav__links {
    position: absolute;
    right: clamp(20px, 4.24vw, 61px);
    display: flex;
    align-items: center;
    gap: clamp(12px, 2.78vw, 40px);
  }

  .nav__login {
    position: relative;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 4.2px;
    text-transform: uppercase;
    color: var(--color-muted);
    font-feature-settings: 'dlig';
  }

  .nav__login::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }

  .nav__login:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav__link {
    position: relative;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 4.2px;
    text-transform: uppercase;
    color: var(--color-pop-accessible);
    font-feature-settings: 'dlig';
  }

  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }

  .nav__link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav__cart {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 4.2px;
    text-transform: uppercase;
    color: var(--color-pop-accessible);
    font-feature-settings: 'dlig';
  }

  .nav__cart::after {
    display: none !important;
  }

  .nav__cart-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding-right: 1px;
    padding-top: 1.5px;
    margin-left: 0;
    background: var(--color-pop);
    color: var(--color-white);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0;
    border-radius: 100px;
    vertical-align: middle;
    transform: scale(1);
    transition: transform 0.2s ease;
  }

  .nav__cart:hover .nav__cart-count {
    transform: scale(1.15);
  }

  .nav__cart-count:empty,
  .nav__cart-count--zero,
  .nav__cart:hover .nav__cart-count:empty,
  .nav__cart:hover .nav__cart-count--zero {
    transform: scale(0);
    width: 0;
    overflow: hidden;
  }

  .nav__cart-label {
    position: relative;
  }

  .nav__cart-label::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }

  .nav__cart:hover .nav__cart-label::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (max-width: 768px) {
    .nav {
      justify-content: space-between;
      align-items: center;
    }

    .nav__left {
      display: none;
    }

    .nav__links {
      position: static;
    }

    .nav__cart,
    .nav__login {
      display: none;
    }

    .nav__logo-full {
      display: none;
    }

    .nav__logo-sm {
      display: block;
    }
  }
</style>

<script>
  const countEl = document.querySelector('.nav__cart-count');
  if (countEl) {
    function updateZero() {
      countEl.classList.toggle('nav__cart-count--zero', !countEl.textContent || countEl.textContent.trim() === '0');
    }
    updateZero();
    new MutationObserver(updateZero).observe(countEl, { childList: true, characterData: true, subtree: true });
  }
</script>
